# Sunglow — environment variables
# Copy to .env.local for local dev; set the same keys in the Vercel project.

# --- Database (Neon Postgres, pooled connection string) ---
# Stores Web Push subscriptions + their saved location.
DATABASE_URL=

# --- Web Push (VAPID) ---
# Generate a keypair once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sunglow@example.com
# Same value as VAPID_PUBLIC_KEY, exposed to the client (SvelteKit needs the PUBLIC_ prefix).
PUBLIC_VAPID_PUBLIC_KEY=

# --- Cron protection ---
# Gates /api/cron (Authorization: Bearer <secret>  OR  ?key=<secret>).
# Generate with: openssl rand -hex 24
CRON_SECRET=

# Public origin used to build notification deep-links (falls back to request origin).
APP_URL=

# --- Optional: deterrent token on /api/push/{subscribe,unsubscribe} ---
# Keep both identical. Generate with: openssl rand -hex 24
SUBSCRIBE_TOKEN=
PUBLIC_SUBSCRIBE_TOKEN=

# --- Notification tuning (defaults applied in code if unset) ---
SUNSET_SCORE_MIN=80
SUNSET_CONFIDENCE_MIN=70
NOTIFY_LEAD_HOURS=2
